<Window x:Class="ClickyWindows.SetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Clicky — Setup"
        Width="480" Height="520"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="#1a1a1a"
        Foreground="White"
        FontFamily="Segoe UI">

    <Window.Resources>
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#aaaaaa"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,12,0,4"/>
        </Style>
        <Style x:Key="InputStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#2a2a2a"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Consolas"/>
        </Style>
        <Style x:Key="SecretInputStyle" TargetType="PasswordBox">
            <Setter Property="Background" Value="#2a2a2a"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Consolas"/>
        </Style>
        <Style x:Key="LinkStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#5b9bd5"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,2,0,0"/>
        </Style>
    </Window.Resources>

    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Welcome to Clicky" FontSize="22" FontWeight="SemiBold" Foreground="White"/>
            <TextBlock Text="Paste your API keys to get started. These are stored locally on your machine."
                       Foreground="#888" FontSize="13" Margin="0,6,0,0" TextWrapping="Wrap"/>
        </StackPanel>

        <!-- Fields -->
        <StackPanel Grid.Row="1">

            <TextBlock Text="ANTHROPIC API KEY" Style="{StaticResource LabelStyle}"/>
            <PasswordBox x:Name="AnthropicKeyBox" Style="{StaticResource SecretInputStyle}"/>
            <TextBlock Style="{StaticResource LinkStyle}" MouseLeftButtonUp="OpenAnthropicConsole">
                → Get key at console.anthropic.com
            </TextBlock>

            <TextBlock Text="ASSEMBLYAI API KEY" Style="{StaticResource LabelStyle}"/>
            <PasswordBox x:Name="AssemblyAiKeyBox" Style="{StaticResource SecretInputStyle}"/>
            <TextBlock Style="{StaticResource LinkStyle}" MouseLeftButtonUp="OpenAssemblyAiConsole">
                → Get key at assemblyai.com
            </TextBlock>

            <TextBlock Text="ELEVENLABS API KEY" Style="{StaticResource LabelStyle}"/>
            <PasswordBox x:Name="ElevenLabsKeyBox" Style="{StaticResource SecretInputStyle}"/>
            <TextBlock Style="{StaticResource LinkStyle}" MouseLeftButtonUp="OpenElevenLabsConsole">
                → Get key at elevenlabs.io (Starter plan required)
            </TextBlock>

            <TextBlock Text="ELEVENLABS VOICE ID" Style="{StaticResource LabelStyle}"/>
            <TextBox x:Name="VoiceIdBox" Style="{StaticResource InputStyle}"/>
            <TextBlock Foreground="#666" FontSize="11" Margin="0,2,0,0" TextWrapping="Wrap">
                Find this in ElevenLabs → Voices → click a voice → copy the ID from the URL
            </TextBlock>

        </StackPanel>

        <!-- Save button + error -->
        <StackPanel Grid.Row="2" Margin="0,20,0,0">
            <TextBlock x:Name="ErrorText" Foreground="#e05555" FontSize="12"
                       Visibility="Collapsed" Margin="0,0,0,8" TextWrapping="Wrap"/>
            <Button x:Name="SaveButton" Content="Save and Launch Clicky"
                    Click="OnSaveClicked"
                    Background="#4a9eff" Foreground="White"
                    BorderThickness="0" Padding="0,12"
                    FontSize="14" FontWeight="SemiBold" Cursor="Hand">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#4a9eff"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding" Value="0,12"/>
                        <Setter Property="FontSize" Value="14"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="6" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3a8eef"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>
    </Grid>
</Window>
