<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <!-- Windows 10 19041 target gives us access to modern Windows APIs -->
    <TargetFramework>net8.0-windows10.0.19041.0</TargetFramework>
    <UseWPF>true</UseWPF>
    <!-- WinForms is included solely for System.Windows.Forms.NotifyIcon (system tray) -->
    <UseWindowsForms>true</UseWindowsForms>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AssemblyName>ClickyWindows</AssemblyName>
    <RootNamespace>ClickyWindows</RootNamespace>
    <ApplicationManifest>app.manifest</ApplicationManifest>
  </PropertyGroup>

  <ItemGroup>
    <!-- NAudio handles mic capture (WaveInEvent) and TTS audio playback (Mp3FileReader + WaveOutEvent) -->
    <PackageReference Include="NAudio" Version="2.2.1" />
  </ItemGroup>

</Project>
