<Window
    x:Class="ClickyWindows.CompanionPanelWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Clicky"
    Width="300"
    SizeToContent="Height"
    WindowStyle="None"
    AllowsTransparency="True"
    ShowInTaskbar="False"
    Topmost="True"
    ResizeMode="NoResize">

    <Window.Resources>
        <!-- Shared button style: dark rounded pill, blue on hover -->
        <Style x:Key="PanelButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#22FFFFFF"/>
            <Setter Property="Foreground" Value="#CCFFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#4488BBFF"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#6688BBFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Main dark panel container -->
    <Border CornerRadius="14"
            Padding="20,18"
            BorderThickness="1"
            BorderBrush="#33FFFFFF">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#F0111122" Offset="0"/>
                <GradientStop Color="#F0080814" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Border.Effect>
            <DropShadowEffect Color="#AA000000" BlurRadius="24" ShadowDepth="8" Direction="270"/>
        </Border.Effect>

        <StackPanel>
            <!-- Header row: app name + close button -->
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Blue dot indicator -->
                    <Ellipse Width="8" Height="8" Margin="0,0,8,0">
                        <Ellipse.Fill>
                            <RadialGradientBrush>
                                <GradientStop Color="#FF88BBFF" Offset="0"/>
                                <GradientStop Color="#FF3366CC" Offset="1"/>
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                    </Ellipse>
                    <TextBlock Text="Clicky"
                               Foreground="White"
                               FontSize="16"
                               FontFamily="Segoe UI"
                               FontWeight="SemiBold"/>
                </StackPanel>

                <Button Grid.Column="1"
                        x:Name="CloseButton"
                        Content="✕"
                        Width="28" Height="28"
                        Padding="0"
                        FontSize="12"
                        Style="{StaticResource PanelButtonStyle}"
                        Click="OnClosePanelClicked"
                        ToolTip="Close panel (app stays in tray)"/>
            </Grid>

            <!-- Status text showing current voice state -->
            <TextBlock x:Name="StatusLabel"
                       Text="Ready — hold Ctrl+Alt to talk"
                       Foreground="#AA8899CC"
                       FontSize="12"
                       FontFamily="Segoe UI"
                       FontStyle="Italic"
                       Margin="0,0,0,16"
                       TextWrapping="Wrap"/>

            <!-- Last heard transcript -->
            <TextBlock x:Name="TranscriptLabel"
                       Foreground="#668899BB"
                       FontSize="11"
                       FontFamily="Segoe UI"
                       FontStyle="Italic"
                       Margin="0,0,0,14"
                       TextWrapping="Wrap"
                       Visibility="Collapsed"/>

            <Separator Background="#22FFFFFF" Margin="0,0,0,14"/>

            <!-- Model picker -->
            <TextBlock Text="Model"
                       Foreground="#66AABBCC"
                       FontSize="11"
                       FontFamily="Segoe UI"
                       Margin="0,0,0,8"/>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                <RadioButton x:Name="SonnetRadio"
                             Content="Sonnet 4.6"
                             IsChecked="True"
                             Foreground="#CCFFFFFF"
                             FontSize="12"
                             FontFamily="Segoe UI"
                             Margin="0,0,16,0"
                             Cursor="Hand"
                             Checked="OnModelSelectionChanged"
                             Tag="claude-sonnet-4-6"/>
                <RadioButton x:Name="OpusRadio"
                             Content="Opus 4.6"
                             Foreground="#CCFFFFFF"
                             FontSize="12"
                             FontFamily="Segoe UI"
                             Cursor="Hand"
                             Checked="OnModelSelectionChanged"
                             Tag="claude-opus-4-6"/>
            </StackPanel>

            <Separator Background="#22FFFFFF" Margin="0,0,0,14"/>

            <!-- Cursor toggle -->
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="Show Clicky cursor"
                           Foreground="#CCFFFFFF"
                           FontSize="13"
                           FontFamily="Segoe UI"
                           VerticalAlignment="Center"/>
                <CheckBox Grid.Column="1"
                          x:Name="CursorToggle"
                          IsChecked="True"
                          VerticalAlignment="Center"
                          Cursor="Hand"
                          Checked="OnCursorToggleChanged"
                          Unchecked="OnCursorToggleChanged"/>
            </Grid>

            <!-- Quit button -->
            <Button Content="Quit Clicky"
                    Style="{StaticResource PanelButtonStyle}"
                    HorizontalAlignment="Stretch"
                    Margin="0,4,0,0"
                    Click="OnQuitClicked"/>
        </StackPanel>
    </Border>
</Window>
